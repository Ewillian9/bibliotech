{% extends 'base.html.twig' %}

{% block title %}{{ book.title }} - Détails{% endblock %}

{% block body %}
<div class="container mx-auto px-6 py-12">
    <!-- ✅ Titre du livre -->
    <h1 class="text-4xl font-bold text-center text-gray-800 mb-10">{{ book.title }}</h1>

    <div class="bg-white p-8 rounded-lg shadow-lg max-w-4xl mx-auto flex flex-col md:flex-row gap-8">
        <!-- ✅ Image du livre -->
        {% if book.thumbnail %}
            <div class="flex-shrink-0 mx-auto md:mx-0">
                <img src="{{ book.thumbnail }}" alt="{{ book.title }}" class="rounded-lg shadow-md max-h-96">
            </div>
        {% endif %}

        <!-- ✅ Informations du livre -->
        <div class="flex-1">
            <div class="mb-4">
                <h2 class="text-lg font-semibold text-gray-700">Auteur(s) :</h2>
                <p class="text-gray-600">{{ book.authors ? book.authors|join(', ') : 'Auteur(s) inconnu(s)' }}</p>
            </div>

            <div class="mb-4">
                <h2 class="text-lg font-semibold text-gray-700">Description :</h2>
                <p class="text-gray-700">{{ book.description ?: 'Aucune description disponible.' }}</p>
            </div>

            <div class="mb-4">
                <h2 class="text-lg font-semibold text-gray-700">ISBN :</h2>
                <p class="text-gray-700">{{ book.isbn ?: 'Non disponible' }}</p>
            </div>

            <div class="mb-4">
                <h2 class="text-lg font-semibold text-gray-700">Date de publication :</h2>
                <p class="text-gray-700">{{ book.publishedDate ?: 'Date non disponible' }}</p>
            </div>

            <!-- ✅ Bouton de retour -->
            <div class="mt-6">
                <a href="{{ path('home') }}" class="inline-block px-6 py-3 rounded-lg bg-blue-600 text-white font-semibold hover:bg-blue-700 transition">
                    ⬅ Retour à la liste
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

